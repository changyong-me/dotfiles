{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": ["api.github.com"]
    }
  },
  "model": "opus[1m]",
  "effortLevel": "high",
  "autoMemoryEnabled": false
}
